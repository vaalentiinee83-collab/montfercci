<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — MONTFERCCI Paris</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Lora:wght@400;500;700&family=Montserrat:wght@300;400&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<header>
  <a href="{{ routes.root_url }}" class="logo-link">
    {% render 'logo' %}
    <span class="logo-tagline">Habiller l'ambition.</span>
  </a>
  <button class="burger" id="burger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</header>

<div class="menu-overlay" id="menuOverlay"></div>
<nav class="dropdown-menu" id="dropdownMenu">
  <a href="{{ routes.root_url }}">Nos Tieleurs</a>
  {% for link in linklists.main-menu.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {% endfor %}
  <a href="{{ pages['notre-histoire'].url | default: '/pages/notre-histoire' }}">Notre Histoire</a>
</nav>

<main role="main">
  {{ content_for_layout }}
</main>

<footer>
  <p class="footer-label">Suivez la confection de notre collection</p>
  <div class="social-links">
    <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
    </a>
    <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" class="social-link" aria-label="TikTok">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.12 8.12 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1-.07z" opacity=".9"/></svg>
    </a>
  </div>
  <p class="footer-bottom">© {{ 'now' | date: '%Y' }} Montfercci Paris — contact@montfercci.com</p>
</footer>

{{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
